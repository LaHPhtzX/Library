            Para.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
            Para.Parent = Page
            Instance.new("UICorner", Para).CornerRadius = UDim.new(0, 8)
            
            local T = Instance.new("TextLabel")
            T.Size = UDim2.new(1, -20, 0, 30)
            T.Position = UDim2.new(0, 10, 0, 5)
            T.Text = Title
            T.TextColor3 = Color3.fromRGB(255, 255, 255)
            T.Font = Enum.Font.GothamBold
            T.TextSize = 17
            T.BackgroundTransparency = 1
            T.Parent = Para
            
            local C = Instance.new("TextLabel")
            C.Size = UDim2.new(1, -20, 1, -40)
            C.Position = UDim2.new(0, 10, 0, 30)
            C.Text = Content
            C.TextColor3 = Color3.fromRGB(160, 160, 160)
            C.Font = Enum.Font.Gotham
            C.TextSize = 15
            C.TextWrapped = true
            C.TextXAlignment = Enum.TextXAlignment.Left
            C.BackgroundTransparency = 1
            C.Parent = Para
        end

        function Items:AddColorpicker(Text, Default, Callback)
            local CFrame = Instance.new("TextButton")
            CFrame.Size = UDim2.new(0.95, 0, 0, 45)
            CFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
            CFrame.Text = "  " .. Text
            CFrame.TextColor3 = Color3.fromRGB(230, 230, 230)
            CFrame.Font = Enum.Font.Gotham
            CFrame.TextSize = 17
            CFrame.TextXAlignment = Enum.TextXAlignment.Left
            CFrame.Parent = Page
            Instance.new("UICorner", CFrame).CornerRadius = UDim.new(0, 8)
            
            local ColorDisplay = Instance.new("Frame")
            ColorDisplay.Size = UDim2.new(0, 35, 0, 22)
            ColorDisplay.Position = UDim2.new(1, -45, 0.5, -11)
            ColorDisplay.BackgroundColor3 = Default
            ColorDisplay.Parent = CFrame
            Instance.new("UICorner", ColorDisplay).CornerRadius = UDim.new(0, 4)
            
            CFrame.MouseButton1Click:Connect(function()
                local RandomColor = Color3.fromHSV(math.random(), 1, 1)
                ColorDisplay.BackgroundColor3 = RandomColor
                Callback(RandomColor)
            end)
        end

        return Items
    end
    return WindowFunctions
end

return Library
