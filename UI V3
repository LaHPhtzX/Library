    Title.BackgroundTransparency = 1
    Title.Parent = Main

    -- RGB Title Effect
    task.spawn(function()
        while task.wait() do
            Title.TextColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1)
        end
    end)

    local Sidebar = Instance.new("ScrollingFrame")
