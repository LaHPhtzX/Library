    ToggleBtn.Position = UDim2.new(0, 20, 0.4, 0)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
    ToggleBtn.Text = "ON"
    ToggleBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.TextSize = 16
